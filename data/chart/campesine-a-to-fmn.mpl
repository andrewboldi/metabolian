# Ingested from Rhea. The spine follows the carbon skeleton from
# campesine A(1+) to FMN(3−); everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway campesine-a-to-fmn "campesine A to FMN" {
  spacing 164

  spine at 0,0 {
    campesine_a
    <-> . +sam -sah -hplus
    campesine_b
    <-> . +campesine_c +fmnh2 +o2 -fmn -h2o -hplus
