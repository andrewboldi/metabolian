  }

  branch from sah side left {
    sah
    <-> . +3_4_5_o_trimethylmyricetin_3_7_diolate +sam
    7_3_4_5_o_tetramethylmyricetin_3_olate
  }

  branch from sah side right {
    sah
    <-> . +kaempferol_oxoanion +sam +hplus
    3_o_methylkaempferol_7_olate
  }
}
