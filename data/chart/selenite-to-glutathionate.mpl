# Ingested from Rhea. The spine follows the carbon skeleton from
# selenite(2−) to glutathionate(1−); everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway selenite-to-glutathionate "selenite to glutathionate" {
  spacing 152

  spine at 0,0 {
    selenite
    <-> . +gsh +hplus -gssg -h2o
    selenodiglutathione
    <-> . +nadph +hplus -gsh -nadp
    glutathioselenol
    <-> . +nadph -gsh -nadp
    selanide
  }

  branch from gssg side left {
    gssg
    <-> . +12_r_hpete +gsh +h2o
    12_r_hete
  }

  branch from gsh side right {
    gsh
    <-> . +prostaglandin_a2
    s_pga2_s_glutathione_conjugate
  }
}
