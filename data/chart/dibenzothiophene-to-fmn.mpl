# Ingested from Rhea. The spine follows the carbon skeleton from
# dibenzothiophene to FMN(3−); everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway dibenzothiophene-to-fmn "dibenzothiophene to FMN" {
  spacing 170

  spine at 0,0 {
    dibenzothiophene
    <-> . +fmnh2 +o2 -fmn -h2o -hplus
    dibenzothiophene_5_oxide
    <-> . +fmnh2 +o2 -fmn -h2o -hplus
    dibenzothiophene_sulfone
    <-> . +fmn_n5_peroxide -fmn_n5_oxide -hplus
    2_hydroxybiphenyl_2_sulfinate
    <-> . +fmn_n5_oxide +nadh +hplus -nad -h2o
    fmn
  }

  branch from fmn side left {
    fmn
    <-> . +12_hete +fmnh2 +o2 +h2o +hplus
    12_20_dihete
  }

  branch from fmn side right {
    fmn
    <-> . +6_trans_leukotriene_b4 +fmnh2 +o2 +h2o +hplus
    20_hydroxy_6_trans_leukotriene_b4
  }

  branch from fmn_n5_oxide side left {
    fmn_n5_oxide
    <-> . +fmn_n5_peroxide +dibenzothiophene_5_5_dioxide
    2_hydroxybiphenyl_2_sulfinate
  }
}
