# sphinganine(1+) to heptadecanal; everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway sphinganine-to-heptadecanal "sphinganine to heptadecanal" {
  spacing 176

  spine at 0,0 {
    sphinganine
    <-> . +stearoyl_coa -coa -hplus
