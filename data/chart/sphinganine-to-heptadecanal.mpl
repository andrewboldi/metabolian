    <-> . +hplus -co2 -h2o
    heptadecanal
  }

  branch from sphinganine side left {
    sphinganine
    <-> . +h2o +pi
    sphinganine_1_phosphate
  }

  branch from octadecanoate side right {
    octadecanoate
    <-> . +1_octadecanoyl_2_9z_octadecenoyl_sn_glycerol +h2o +hplus
    2_oleoylglycerol
  }
