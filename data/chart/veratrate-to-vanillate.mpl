# Ingested from Rhea. The spine follows the carbon skeleton from
# veratrate(1-) to vanillate; everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway veratrate-to-vanillate "veratrate to vanillate" {
  spacing 280

  spine at 0,0 {
    veratrate
    <-> . +hydrogen_donor +o2 -formaldehyde -hydrogen_acceptor -h2o
    vanillate
    <-> ec_2_4_1_136 [2.4.1.136] +udp_d_glucose -udp
    1_o_vanilloyl_d_glucose
    <-> ec_2_4_1_300 [2.4.1.300] +cyanidin_3_o_d_glucoside -vanillate
    cyanidin_3_7_di_o_d_glucoside_betaine
  }

  branch from formaldehyde side left {
    formaldehyde
    <-> . +chlorotoluron +di_sulfido_diiron +o2 +hplus +di_sulfido_diiron +h2o
    3_3_chloro_4_methylphenyl_1_methylurea
  }

  branch from hydrogen_acceptor side right {
    hydrogen_acceptor
    <-> . +verruculide_c +hydrogen_donor +o2 +h2o
    verruculide_c_epoxide
  }
}
