# Ingested from Rhea. The spine follows the carbon skeleton from
# veratrate(1-) to vanillate; everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway veratrate-to-vanillate "veratrate to vanillate" {
  spacing 280

  spine at 0,0 {
    veratrate
    <-> . +hydrogen_donor +o2 -formaldehyde -hydrogen_acceptor -h2o
