    <-> ec_2_4_1_136 [2.4.1.136] +udp_d_glucose -udp
    1_o_vanilloyl_d_glucose
    <-> ec_2_4_1_300 [2.4.1.300] +cyanidin_3_o_d_glucoside -vanillate
    cyanidin_3_7_di_o_d_glucoside_betaine
  }

  branch from formaldehyde side left {
    formaldehyde
    <-> ec_1_14_13_247 [1.14.13.247] +l_proline_betaine +nadh +o2 +hplus +nad +h2o
    n_methylproline
  }

  branch from hydrogen_acceptor side right {
    hydrogen_acceptor
    <-> . +all_cis_5_8_11_14_17_icosapentaenoate +hydrogen_donor +o2 +h2o
    15_r_hepe
  }
}
