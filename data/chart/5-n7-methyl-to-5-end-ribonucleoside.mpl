# Ingested from Rhea. The spine follows the carbon skeleton from
# 5'-(N7-methyl 5'-triphosphoguanosine)-ribonucleoside(2−) residue to 5'-end ribonucleoside 5'-diphosphate(3−) residue; everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway 5-n7-methyl-to-5-end-ribonucleoside "5'-(N7-methyl… to 5'-end ribonucleoside…" {
