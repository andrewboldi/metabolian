# Ingested from Rhea. The spine follows the carbon skeleton from
# (+)-iridodial lactol to FMN(3−); everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway iridodial-lactol-to-fmn "(+)-iridodial lactol to FMN" {
  spacing 164

  spine at 0,0 {
    iridodial_lactol
    <-> . +fmnh2 +o2 -fmn -h2o -hplus
    7_deoxyloganetic_alcohol
    <-> . +fmnh2 +o2 -fmn -h2o -hplus
    7_deoxyloganetic_aldehyde
    <-> . +fmnh2 +o2 -fmn -h2o -hplus
    7_deoxyloganetate
  }

  branch from fmn side left {
    fmn
    <-> . +arachidonate +fmnh2 +o2 +h2o +hplus
    5_6_eet
  }

  branch from fmn side right {
    fmn
    <-> . +arachidonate +fmnh2 +o2 +h2o +hplus
    17_hete
  }
}
