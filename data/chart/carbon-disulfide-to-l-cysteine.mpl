# Ingested from Rhea. The spine follows the carbon skeleton from
# carbon disulfide to L-cysteine; everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway carbon-disulfide-to-l-cysteine "carbon disulfide to L-cysteine" {
  spacing 256

  spine at 0,0 {
    carbon_disulfide
    <-> . +h2o -h2s -hplus
    carbonyl_sulfide
    <-> ec_1_8_1_18 [1.8.1.18] +h2s +nad -nadh
    sulfur_atom
    <-> . +l_alanine
    l_cysteine
  }

  branch from l_cysteine side left {
    l_cysteine
    <-> . +cmp +h +n_r_4_phosphopantothenoyl_l_cysteine
    r_4_phosphopantothenoyl_cytidylate
  }

  branch from l_cysteine side right {
    l_cysteine
    <-> . +nadh +h +7_oxoheptanoic_acid +l_serine +nad
    7_mercaptoheptanoic_acid
  }
}
