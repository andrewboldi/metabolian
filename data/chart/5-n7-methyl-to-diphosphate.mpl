# Ingested from Rhea. The spine follows the carbon skeleton from
# 5'-(N7-methyl 5'-triphosphoguanosine)-ribonucleoside(2−) residue to diphosphate(3−); everything entering or leaving at the
# side is a cofactor on that step. Generated by tools/ingest/build-modules.mjs —
# edit the generator, not this file.

pathway 5-n7-methyl-to-diphosphate "5'-(N7-methyl… to diphosphate" {
  spacing 170

  spine at 0,0 {
    5_n7_methyl_5_triphosphoguanosine_ribonucleoside
    <-> . +sam -sah -hplus
