  "regulations": [
    { "id": "reg_da_th", "type": "feedback-inhibition", "regulator": { "kind": "metabolite", "id": "dopamine" }, "target": { "kind": "enzyme", "id": "th" }, "effect": "negative", "mechanism": "End-product feedback: cytosolic dopamine competitively occupies the tetrahydrobiopterin site of tyrosine hydroxylase, holding the rate-limiting enzyme largely inhibited at rest. This is the dominant minute-to-minute control of catecholamine synthesis.", "provenance": { "confidence": "high", "sources": [{ "db": "textbook", "id": "Lehninger 8e" }, { "db": "PubMed", "id": "15569247" }] } },
    { "id": "reg_ne_th", "type": "feedback-inhibition", "regulator": { "kind": "metabolite", "id": "norepinephrine" }, "target": { "kind": "enzyme", "id": "th" }, "effect": "negative", "mechanism": "Noradrenaline feedback-inhibits tyrosine hydroxylase by competing with the BH4 cofactor, coupling the noradrenergic pool size to the synthesis rate.", "provenance": { "confidence": "high", "sources": [{ "db": "textbook", "id": "Lehninger 8e" }, { "db": "PubMed", "id": "15569247" }] } },
    { "id": "reg_pka_th", "type": "phosphorylation", "regulator": { "kind": "enzyme", "id": "pka" }, "target": { "kind": "enzyme", "id": "th" }, "effect": "positive", "mechanism": "PKA phosphorylates tyrosine hydroxylase at Ser40 (with CaMKII/PKC at Ser19/Ser31 and ERK1/2 also contributing). Phosphorylation lowers TH's affinity for the inhibitory catecholamine end-products and raises Vmax, acutely activating synthesis in response to adrenergic (cAMP) and depolarizing (Ca2+) stimuli.", "provenance": { "confidence": "high", "sources": [{ "db": "PubMed", "id": "15569247" }, { "db": "textbook", "id": "Lehninger 8e" }] } },
    { "id": "reg_sah_comt", "type": "feedback-inhibition", "regulator": { "kind": "metabolite", "id": "sah" }, "target": { "kind": "enzyme", "id": "comt" }, "effect": "negative", "mechanism": "S-adenosyl-L-homocysteine, the product of every COMT-catalyzed transfer, is a competitive product inhibitor of the enzyme; the cellular SAM:SAH ratio therefore governs catecholamine O-methylation capacity and ties degradation to the methionine cycle.", "provenance": { "confidence": "high", "sources": [{ "db": "textbook", "id": "Lehninger 8e" }, { "db": "PubMed", "id": "15317907" }] } },
    { "id": "reg_sah_pnmt", "type": "feedback-inhibition", "regulator": { "kind": "metabolite", "id": "sah" }, "target": { "kind": "enzyme", "id": "pnmt" }, "effect": "negative", "mechanism": "SAH product-inhibits phenylethanolamine N-methyltransferase, so a falling SAM:SAH ratio restrains adrenaline biosynthesis.", "provenance": { "confidence": "medium", "sources": [{ "db": "textbook", "id": "Lehninger 8e" }, { "db": "PubMed", "id": "15317907" }] } },
    { "id": "reg_cortisol_pnmt", "type": "transcriptional-activation", "regulator": { "kind": "metabolite", "id": "cortisol" }, "target": { "kind": "gene", "id": "pnmt_gene" }, "effect": "positive", "mechanism": "Adrenal cortical glucocorticoids reach the medulla at high concentration through the intra-adrenal portal circulation and, via the glucocorticoid receptor, induce PNMT gene transcription. This anatomical arrangement makes adrenaline synthesis cortisol-dependent and explains the fall in adrenaline output when the cortex fails.", "provenance": { "confidence": "high", "sources": [{ "db": "PubMed", "id": "19342614" }, { "db": "textbook", "id": "Lehninger 8e" }] } },
    { "id": "reg_cortisol_th", "type": "transcriptional-activation", "regulator": { "kind": "metabolite", "id": "cortisol" }, "target": { "kind": "gene", "id": "th_gene" }, "effect": "positive", "mechanism": "Glucocorticoids and preganglionic (splanchnic) sympathetic input induce tyrosine hydroxylase (and DBH) gene expression in chromaffin cells during chronic stress, providing longer-term up-regulation of catecholamine biosynthetic capacity.", "provenance": { "confidence": "medium", "sources": [{ "db": "PubMed", "id": "19342614" }] } }
  ],
  "relations": [
    { "id": "rel_ge_th", "type": "gene-encodes", "source": { "kind": "gene", "id": "th_gene" }, "target": { "kind": "enzyme", "id": "th" }, "note": "TH encodes tyrosine hydroxylase." },
    { "id": "rel_ge_dbh", "type": "gene-encodes", "source": { "kind": "gene", "id": "dbh_gene" }, "target": { "kind": "enzyme", "id": "dbh" }, "note": "DBH encodes dopamine β-hydroxylase." },
    { "id": "rel_ge_pnmt", "type": "gene-encodes", "source": { "kind": "gene", "id": "pnmt_gene" }, "target": { "kind": "enzyme", "id": "pnmt" }, "note": "PNMT encodes phenylethanolamine N-methyltransferase." },
    { "id": "rel_iso_mao", "type": "isozyme", "source": { "kind": "enzyme", "id": "maoa" }, "target": { "kind": "enzyme", "id": "maob" }, "note": "MAO-A and MAO-B are ~70% identical isozymes with distinct substrate preferences and inhibitor sensitivities; both deaminate catecholamines." },
    { "id": "rel_ct_sam_met", "type": "crosstalk", "source": { "kind": "metabolite", "id": "sam" }, "target": { "kind": "pathway", "id": "methionine-cysteine-metabolism" }, "note": "PNMT and COMT are SAM-dependent methyltransferases: catecholamine N-/O-methylation consumes S-adenosylmethionine and releases S-adenosylhomocysteine, coupling catecholamine turnover to the methionine cycle and one-carbon metabolism." },
    { "id": "rel_ct_tyr_phe", "type": "crosstalk", "source": { "kind": "metabolite", "id": "tyrosine" }, "target": { "kind": "pathway", "id": "phenylalanine-tyrosine-metabolism" }, "note": "L-Tyrosine, the entry substrate, is obtained from dietary protein and from phenylalanine via phenylalanine hydroxylase; catecholamine synthesis competes with tyrosine's routes to melanin, thyroid hormone and protein." },
    { "id": "rel_ct_bh4_pterin", "type": "crosstalk", "source": { "kind": "metabolite", "id": "bh4" }, "target": { "kind": "pathway", "id": "tetrahydrobiopterin-metabolism" }, "note": "Tyrosine hydroxylase depends on tetrahydrobiopterin, made de novo from GTP and regenerated from dihydrobiopterin by dihydropteridine reductase (QDPR); BH4 is shared with the other aromatic amino-acid hydroxylases and NO synthases." },
    { "id": "rel_ct_asc_vitc", "type": "crosstalk", "source": { "kind": "metabolite", "id": "ascorbate" }, "target": { "kind": "pathway", "id": "ascorbate-metabolism" }, "note": "Dopamine β-hydroxylase consumes ascorbate (vitamin C) as its physiological electron donor, oxidizing it to the monodehydroascorbate radical inside catecholamine storage vesicles." },
    { "id": "rel_ct_h2o2_redox", "type": "crosstalk", "source": { "kind": "metabolite", "id": "h2o2" }, "target": { "kind": "pathway", "id": "glutathione-metabolism" }, "note": "MAO deamination generates hydrogen peroxide and reactive catecholaldehydes (DOPAL, DOPEGAL); their detoxification by glutathione peroxidase and ALDH links catecholamine turnover to cellular redox and is implicated in dopaminergic neurodegeneration." }
