{
  "$schema": "../../schema/pathway.schema.json",
  "id": "fatty-acid-synthesis",
  "name": "De novo fatty acid synthesis (palmitate synthesis)",
  "category": "lipid-metabolism",
  "summary": "Cytosolic pathway that builds the 16-carbon saturated fatty acid palmitate from acetyl-CoA and malonyl-CoA, consuming 14 NADPH per palmitate; the committed, rate-limiting step is acetyl-CoA carboxylase.",
  "description": "De novo lipogenesis converts excess dietary carbohydrate and protein carbon into fatty acids for storage and membrane building. Acetyl-CoA generated in the mitochondrion is exported to the cytosol as citrate and cleaved by ATP-citrate lyase (ACLY) back to acetyl-CoA and oxaloacetate. Acetyl-CoA carboxylase (ACC1 / ACACA) then carboxylates acetyl-CoA to malonyl-CoA — the committed, rate-limiting, and most heavily regulated step. The multifunctional homodimeric fatty acid synthase (FASN) uses one acetyl-CoA primer and seven malonyl-CoA two-carbon donors, iterating a four-reaction cycle (condensation, reduction, dehydration, reduction) seven times and consuming 14 NADPH, to build palmitate, which its thioesterase domain hydrolytically releases. NADPH is supplied largely by the oxidative pentose phosphate pathway and cytosolic malic enzyme. The pathway is reciprocally controlled with fatty-acid oxidation: malonyl-CoA inhibits carnitine palmitoyltransferase 1 (CPT1), preventing simultaneous synthesis and beta-oxidation. Control is both short-term (allosteric activation of ACC by citrate, feedback inhibition by long-chain acyl-CoA, and inhibitory AMPK phosphorylation) and long-term (transcriptional induction of ACACA and FASN by insulin-driven SREBP-1c and glucose-driven ChREBP).",
  "organisms": ["human"],
  "tissues": ["liver", "adipose", "lactating mammary gland", "lung"],
  "keywords": ["de novo lipogenesis", "palmitate", "malonyl-CoA", "fatty acid synthase", "FASN", "acetyl-CoA carboxylase", "citrate shuttle", "NADPH", "SREBP-1c"],
