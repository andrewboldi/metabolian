    { "id": "sdh", "name": "Succinate dehydrogenase / Respiratory Complex II", "subunits": [ { "enzyme": "sdha", "stoichiometry": 1 }, { "enzyme": "sdhb", "stoichiometry": 1 }, { "enzyme": "sdhc", "stoichiometry": 1 }, { "enzyme": "sdhd", "stoichiometry": 1 } ], "xrefs": { "ec": ["1.3.5.1"] }, "description": "The only membrane-bound enzyme of the cycle and Complex II of the electron transport chain. Electrons from succinate flow through covalent FAD (SDHA) and the Fe-S clusters of SDHB to ubiquinone bound at the SDHC/SDHD membrane anchor.", "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R02164" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 16" } ] } },
    { "id": "scs", "name": "Succinyl-CoA synthetase (succinate--CoA ligase, GDP-forming)", "subunits": [ { "enzyme": "suclg1", "stoichiometry": 1 }, { "enzyme": "suclg2", "stoichiometry": 1 } ], "xrefs": { "ec": ["6.2.1.4"] }, "description": "Catalyzes the cycle's only substrate-level phosphorylation. The shared alpha subunit (SUCLG1) carries the catalytic phosphohistidine; the beta subunit sets nucleotide specificity — SUCLG2 (GTP-forming, EC 6.2.1.4) versus SUCLA2 (ATP-forming, EC 6.2.1.5).", "provenance": { "confidence": "high", "sources": [ { "db": "UniProt", "id": "P53597" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 16" } ] } },
    { "id": "pdhc", "name": "Pyruvate dehydrogenase complex (PDH)", "subunits": [ { "enzyme": "pdha1" }, { "enzyme": "pdhb" }, { "enzyme": "dlat" }, { "enzyme": "dld" } ], "xrefs": { "ec": ["1.2.4.1", "2.3.1.12", "1.8.1.4"] }, "description": "The bridge from glycolysis to the cycle: oxidatively decarboxylates pyruvate to acetyl-CoA. E1 (PDHA1/PDHB, ThDP) - E2 (DLAT, lipoyl) - E3 (DLD, FAD). Switched off by phosphorylation of E1-alpha (PDKs) and on by dephosphorylation (PDPs).", "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R00209" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 16" } ] } }
