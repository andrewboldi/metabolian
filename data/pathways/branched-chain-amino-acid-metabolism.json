    { "id": "bcaa16_echs1_val", "name": "Methacrylyl-CoA hydration (valine)", "ec": "4.2.1.17", "equation": "Methacrylyl-CoA + H2O <=> (S)-3-Hydroxyisobutyryl-CoA", "substrates": [{ "metabolite": "methacrylyl_coa" }, { "metabolite": "h2o" }], "products": [{ "metabolite": "hib_coa" }], "catalysts": [{ "enzyme": "echs1", "role": "catalyst" }], "reversibility": "reversible", "pathwayStep": 16, "compartment": "mitochondrion", "xrefs": { "kegg": "R04224" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R04224" }, { "db": "UniProt", "id": "P30084" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }], "notes": "Methacrylyl-CoA is reactive and cytotoxic; rapid hydration by the crotonase ECHS1 is protective." } },
    { "id": "bcaa17_hibch", "name": "3-Hydroxyisobutyryl-CoA hydrolysis (valine)", "ec": "3.1.2.4", "equation": "(S)-3-Hydroxyisobutyryl-CoA + H2O -> (S)-3-Hydroxyisobutyrate + CoA", "substrates": [{ "metabolite": "hib_coa" }, { "metabolite": "h2o" }], "products": [{ "metabolite": "hydroxyisobutyrate" }, { "metabolite": "coa" }], "catalysts": [{ "enzyme": "hibch", "role": "catalyst" }], "reversibility": "irreversible", "pathwayStep": 17, "compartment": "mitochondrion", "xrefs": { "kegg": "R05064" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R05064" }, { "db": "UniProt", "id": "Q6NVY1" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }], "notes": "The valine pathway uniquely hydrolyses the CoA thioester at this point, releasing free (S)-3-hydroxyisobutyrate." } },
    { "id": "bcaa18_hibadh", "name": "3-Hydroxyisobutyrate dehydrogenation (valine)", "ec": "1.1.1.31", "equation": "(S)-3-Hydroxyisobutyrate + NAD+ <=> (S)-Methylmalonate semialdehyde + NADH + H+", "substrates": [{ "metabolite": "hydroxyisobutyrate" }, { "metabolite": "nad" }], "products": [{ "metabolite": "mmsa" }, { "metabolite": "nadh" }, { "metabolite": "hplus" }], "catalysts": [{ "enzyme": "hibadh", "role": "catalyst" }], "cofactors": [{ "metabolite": "nad", "role": "electron acceptor" }], "reversibility": "reversible", "pathwayStep": 18, "compartment": "mitochondrion", "xrefs": { "kegg": "R05066" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R05066" }, { "db": "UniProt", "id": "P31937" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }] } },
    { "id": "bcaa19_aldh6a1", "name": "Methylmalonate-semialdehyde oxidative decarboxylation (valine, terminal)", "ec": "1.2.1.27", "equation": "(S)-Methylmalonate semialdehyde + CoA + NAD+ -> Propionyl-CoA + CO2 + NADH + H+", "substrates": [{ "metabolite": "mmsa" }, { "metabolite": "coa" }, { "metabolite": "nad" }], "products": [{ "metabolite": "propionyl_coa" }, { "metabolite": "co2" }, { "metabolite": "nadh" }, { "metabolite": "hplus" }], "catalysts": [{ "enzyme": "aldh6a1", "role": "catalyst" }], "cofactors": [{ "metabolite": "nad", "role": "electron acceptor" }, { "metabolite": "coa", "role": "acyl acceptor" }], "reversibility": "irreversible", "pathwayStep": 19, "compartment": "mitochondrion", "xrefs": { "kegg": "R00922" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R00922" }, { "db": "UniProt", "id": "Q02252" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }], "notes": "CoA-dependent oxidative decarboxylation to propionyl-CoA. KEGG lists the substrate as C00349 (2-methyl-3-oxopropanoate), the same compound as the HIBADH product (S)-methylmalonate semialdehyde (C06002)." } }
