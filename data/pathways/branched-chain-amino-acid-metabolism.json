    { "id": "bcaa14_acat1", "name": "2-Methylacetoacetyl-CoA thiolysis (isoleucine, terminal)", "ec": "2.3.1.9", "equation": "2-Methylacetoacetyl-CoA + CoA <=> Acetyl-CoA + Propionyl-CoA", "substrates": [{ "metabolite": "maa_coa" }, { "metabolite": "coa" }], "products": [{ "metabolite": "acetyl_coa" }, { "metabolite": "propionyl_coa" }], "catalysts": [{ "enzyme": "acat1", "role": "catalyst" }], "cofactors": [{ "metabolite": "coa", "role": "thiol acceptor" }], "reversibility": "reversible", "pathwayStep": 14, "compartment": "mitochondrion", "xrefs": { "kegg": "R00927" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R00927" }, { "db": "UniProt", "id": "P24752" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }], "notes": "Thiolytic cleavage; KEGG R00927 is written in the synthetic direction. Yields one acetyl-CoA (ketogenic) and one propionyl-CoA (glucogenic), so isoleucine is both ketogenic and glucogenic." } },
