    { "id": "bcaa4_bckdh_leu", "name": "BCKDH: oxidative decarboxylation of alpha-ketoisocaproate (leucine)", "ec": "1.2.4.4", "equation": "4-Methyl-2-oxopentanoate + CoA + NAD+ -> Isovaleryl-CoA + CO2 + NADH", "substrates": [{ "metabolite": "kic" }, { "metabolite": "coa" }, { "metabolite": "nad" }], "products": [{ "metabolite": "isovaleryl_coa" }, { "metabolite": "co2" }, { "metabolite": "nadh" }], "catalysts": [{ "enzyme": "bckdh_complex", "role": "committed-step" }], "cofactors": [{ "metabolite": "nad", "role": "electron acceptor" }, { "metabolite": "coa", "role": "acyl acceptor" }], "reversibility": "irreversible", "rateLimiting": true, "pathwayStep": 4, "compartment": "mitochondrion", "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "map00280" }, { "db": "KEGG", "id": "R07601" }, { "db": "UniProt", "id": "P12694" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }], "notes": "Committed, rate-limiting step. Overall reaction of the BCKDH complex (E1 ThDP decarboxylation, E2 DBT lipoyl transacylation, E3 DLD/FAD reoxidation with NAD+). KEGG models the mechanism as component reactions (E1 decarboxylation of KIC = R07601); no single KEGG id encodes the CoA/NAD+ overall, so it is not placed in xrefs." } },
