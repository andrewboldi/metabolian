    { "id": "bcaa10_hmgcl", "name": "HMG-CoA lyase cleavage (leucine, terminal)", "ec": "4.1.3.4", "equation": "(S)-3-Hydroxy-3-methylglutaryl-CoA -> Acetyl-CoA + Acetoacetate", "substrates": [{ "metabolite": "hmg_coa" }], "products": [{ "metabolite": "acetyl_coa" }, { "metabolite": "acetoacetate" }], "catalysts": [{ "enzyme": "hmgcl", "role": "catalyst" }], "reversibility": "irreversible", "pathwayStep": 10, "compartment": "mitochondrion", "xrefs": { "kegg": "R01360" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R01360" }, { "db": "UniProt", "id": "P35914" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }], "notes": "Terminal leucine step; both products are ketogenic (acetoacetate is a ketone body). The same mitochondrial HMG-CoA lyase is shared with hepatic ketogenesis." } },
