  "regulations": [
    { "id": "reg_bckdk_phos_e1", "type": "phosphorylation", "regulator": { "kind": "enzyme", "id": "bckdk" }, "target": { "kind": "enzyme", "id": "bckdha" }, "effect": "negative", "mechanism": "BCKDH kinase (BCKDK) phosphorylates Ser293 of the E1-alpha subunit (BCKDHA), inactivating the BCKDH complex. This reversible phosphorylation is the dominant short-term control of BCAA oxidation; BCKDK is up-regulated and the complex kept phosphorylated (off) when dietary BCAA supply is low.", "provenance": { "confidence": "high", "sources": [{ "db": "UniProt", "id": "O14874" }, { "db": "PubMed", "id": "30485760" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }] } },
    { "id": "reg_ppm1k_dephos_e1", "type": "dephosphorylation", "regulator": { "kind": "enzyme", "id": "ppm1k" }, "target": { "kind": "enzyme", "id": "bckdha" }, "effect": "positive", "mechanism": "The mitochondrial phosphatase PPM1K (PP2Cm) dephosphorylates BCKDHA, reactivating the BCKDH complex. PPM1K loss keeps the complex phosphorylated and raises circulating BCAAs and branched-chain keto acids, linking the kinase/phosphatase pair to metabolic disease.", "provenance": { "confidence": "high", "sources": [{ "db": "UniProt", "id": "Q8N3J5" }, { "db": "PubMed", "id": "22560213" }] } },
    { "id": "reg_kic_inhibits_bckdk", "type": "allosteric-inhibition", "regulator": { "kind": "metabolite", "id": "kic" }, "target": { "kind": "enzyme", "id": "bckdk" }, "effect": "negative", "mechanism": "Branched-chain 2-oxo acids, most potently alpha-ketoisocaproate (KIC), bind and inhibit BCKDK. Inhibiting the kinase relieves phosphorylation of the complex, so a rising branched-chain keto acid load accelerates its own oxidation (substrate-driven activation of BCKDH).", "provenance": { "confidence": "high", "sources": [{ "db": "PubMed", "id": "30485760" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }] } },
    { "id": "reg_nadh_bckdh", "type": "feedback-inhibition", "regulator": { "kind": "metabolite", "id": "nadh" }, "target": { "kind": "complex", "id": "bckdh_complex" }, "effect": "negative", "mechanism": "NADH inhibits the E3 (DLD) component, so a high mitochondrial NADH/NAD+ ratio slows flux through the BCKDH complex — classic product inhibition analogous to pyruvate dehydrogenase.", "provenance": { "confidence": "high", "sources": [{ "db": "textbook", "id": "Lehninger 8e, Ch. 18" }] } },
    { "id": "reg_acylcoa_bckdh", "type": "feedback-inhibition", "regulator": { "kind": "metabolite", "id": "isovaleryl_coa" }, "target": { "kind": "complex", "id": "bckdh_complex" }, "effect": "negative", "mechanism": "The branched-chain acyl-CoA products (e.g. isovaleryl-CoA) inhibit the E2 (DBT) transacylase, providing product feedback on the committed step.", "provenance": { "confidence": "medium", "sources": [{ "db": "textbook", "id": "Lehninger 8e, Ch. 18" }] } }
  ],
  "relations": [
    { "id": "rel_bcaa_propionylcoa_tca", "type": "crosstalk", "source": { "kind": "metabolite", "id": "propionyl_coa" }, "target": { "kind": "pathway", "id": "citric-acid-cycle" }, "note": "Propionyl-CoA from valine and isoleucine is carboxylated by propionyl-CoA carboxylase and isomerised (via methylmalonyl-CoA, MUT) to succinyl-CoA — an anaplerotic, glucogenic entry into the TCA cycle." },
    { "id": "rel_bcaa_acetylcoa_tca", "type": "crosstalk", "source": { "kind": "metabolite", "id": "acetyl_coa" }, "target": { "kind": "pathway", "id": "citric-acid-cycle" }, "note": "Acetyl-CoA generated from leucine and isoleucine is oxidised in the TCA cycle." },
    { "id": "rel_bcaa_acetoacetate_ketogenesis", "type": "crosstalk", "source": { "kind": "metabolite", "id": "acetoacetate" }, "target": { "kind": "pathway", "id": "ketone-body-metabolism" }, "note": "Leucine is purely ketogenic: its terminal products acetoacetate (a ketone body) and acetyl-CoA connect BCAA catabolism to hepatic ketone-body metabolism, which shares mitochondrial HMG-CoA lyase." },
    { "id": "rel_bcaa_akg_tca", "type": "crosstalk", "source": { "kind": "metabolite", "id": "akg" }, "target": { "kind": "pathway", "id": "citric-acid-cycle" }, "note": "The shared transamination consumes TCA-cycle-derived 2-oxoglutarate and forms glutamate, coupling BCAA nitrogen disposal to the glutamate/2-oxoglutarate pool and the inter-organ nitrogen shuttle (muscle exports glutamine and alanine)." },
    { "id": "rel_bcat_isozymes", "type": "isozyme", "source": { "kind": "enzyme", "id": "bcat1" }, "target": { "kind": "enzyme", "id": "bcat2" }, "note": "BCAT1 (cytosolic; brain, and re-expressed in many cancers) and BCAT2 (mitochondrial; the main peripheral catabolic isoform) are PLP-dependent isozymes catalysing the same reversible transamination." }
  ]
