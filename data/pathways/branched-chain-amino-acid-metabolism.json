    { "id": "bcaa7_ivd", "name": "Isovaleryl-CoA dehydrogenation (leucine)", "ec": "1.3.8.4", "equation": "Isovaleryl-CoA + FAD -> 3-Methylcrotonyl-CoA + FADH2", "substrates": [{ "metabolite": "isovaleryl_coa" }, { "metabolite": "fad" }], "products": [{ "metabolite": "methylcrotonyl_coa" }, { "metabolite": "fadh2" }], "catalysts": [{ "enzyme": "ivd", "role": "catalyst" }], "cofactors": [{ "metabolite": "fad", "role": "hydride/electron acceptor (enzyme-bound; reoxidised by ETF)" }], "reversibility": "irreversible", "pathwayStep": 7, "compartment": "mitochondrion", "xrefs": { "kegg": "R04095" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R04095" }, { "db": "UniProt", "id": "P26440" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }], "notes": "Electrons pass from enzyme-bound FAD to electron-transfer flavoprotein (ETF) and then via ETF-ubiquinone oxidoreductase to the respiratory chain; KEGG also encodes the ETF-coupled form as R04096. IVD deficiency causes isovaleric acidemia." } },
    { "id": "bcaa8_mcc", "name": "3-Methylcrotonyl-CoA carboxylation (leucine)", "ec": "6.4.1.4", "equation": "3-Methylcrotonyl-CoA + ATP + HCO3- -> 3-Methylglutaconyl-CoA + ADP + Pi", "substrates": [{ "metabolite": "methylcrotonyl_coa" }, { "metabolite": "atp" }, { "metabolite": "hco3" }], "products": [{ "metabolite": "methylglutaconyl_coa" }, { "metabolite": "adp" }, { "metabolite": "pi" }], "catalysts": [{ "enzyme": "mcc_complex", "role": "catalyst" }], "cofactors": [{ "metabolite": "atp", "role": "drives carboxylation" }], "reversibility": "irreversible", "pathwayStep": 8, "compartment": "mitochondrion", "xrefs": { "kegg": "R04138" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R04138" }, { "db": "UniProt", "id": "Q96RQ3" }, { "db": "textbook", "id": "Lehninger 8e, Ch. 18" }], "notes": "Biotin-dependent, ATP-driven carboxylation using bicarbonate; the biotin prosthetic group sits on MCCC1." } },
