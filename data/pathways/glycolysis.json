  "$schema": "../../schema/pathway.schema.json",
  "id": "glycolysis",
  "name": "Glycolysis (Embden–Meyerhof–Parnas pathway)",
  "category": "carbohydrate-metabolism",
  "summary": "Ten-step cytosolic pathway that converts one glucose into two pyruvate, netting 2 ATP and 2 NADH.",
  "description": "Glycolysis is the central hub of carbohydrate catabolism. It has an energy-investment phase (steps 1–5, consuming 2 ATP) and an energy-payoff phase (steps 6–10, producing 4 ATP and 2 NADH). Three reactions are effectively irreversible under cellular conditions — catalyzed by hexokinase, phosphofructokinase-1, and pyruvate kinase — and are the principal points of regulation. Pyruvate is then routed to the TCA cycle (aerobic), lactate (anaerobic), or fermentation depending on tissue and oxygen state.",
  "organisms": ["human"],
  "tissues": ["ubiquitous", "erythrocyte", "muscle", "liver", "brain"],
  "keywords": ["glucose", "pyruvate", "ATP", "EMP pathway", "central carbon metabolism"],
