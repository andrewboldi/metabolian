    { "id": "gsr6", "name": "Glycine cleavage system", "ec": "1.4.4.2", "equation": "Glycine + Tetrahydrofolate + NAD+ <=> 5,10-Methylenetetrahydrofolate + CO2 + Ammonia + NADH + H+", "substrates": [ { "metabolite": "glycine" }, { "metabolite": "thf" }, { "metabolite": "nad" } ], "products": [ { "metabolite": "mlthf" }, { "metabolite": "co2" }, { "metabolite": "nh3" }, { "metabolite": "nadh" }, { "metabolite": "hplus" } ], "catalysts": [ { "enzyme": "gcs", "role": "catalyst" } ], "cofactors": [ { "metabolite": "nad", "role": "electron acceptor" }, { "metabolite": "thf", "role": "one-carbon acceptor" } ], "reversibility": "reversible", "pathwayStep": 6, "compartment": "mitochondrion", "xrefs": { "kegg": "R01221" }, "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R01221" }, { "db": "UniProt", "id": "P23378" }, { "db": "PubMed", "id": "20301531" } ] } },
    { "id": "gsr7", "name": "Threonine deamination to 2-oxobutanoate", "ec": "4.3.1.19", "equation": "L-Threonine -> 2-Oxobutanoate + Ammonia + H+", "substrates": [ { "metabolite": "threonine" } ], "products": [ { "metabolite": "oxobut" }, { "metabolite": "nh3" }, { "metabolite": "hplus" } ], "catalysts": [ { "enzyme": "sds", "role": "catalyst" } ], "reversibility": "irreversible", "pathwayStep": 7, "compartment": "cytosol", "xrefs": { "kegg": "R00996" }, "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R00996" }, { "db": "UniProt", "id": "P20132" } ], "notes": "Major human threonine catabolic route; the PLP enzyme SDS acts on both L-serine (EC 4.3.1.17) and L-threonine (EC 4.3.1.19). 2-Oxobutanoate is decarboxylated to propionyl-CoA." } },
    { "id": "gsr8", "name": "Threonine aldol cleavage (SHMT1 side activity)", "ec": "4.1.2.48", "equation": "L-Threonine <=> Glycine + Acetaldehyde", "substrates": [ { "metabolite": "threonine" } ], "products": [ { "metabolite": "glycine" }, { "metabolite": "acetaldehyde" } ], "catalysts": [ { "enzyme": "shmt1", "role": "catalyst" } ], "reversibility": "reversible", "pathwayStep": 8, "compartment": "cytosol", "xrefs": { "kegg": "R00751" }, "provenance": { "confidence": "medium", "sources": [ { "db": "KEGG", "id": "R00751" }, { "db": "UniProt", "id": "P34896" } ], "notes": "Humans lack a dedicated threonine aldolase (GLY1 is a pseudogene); this low-specificity L-threonine aldolase activity is a minor side reaction of SHMT1 (EC 4.1.2.48)." } },
    { "id": "gsr9", "name": "2-Amino-3-oxobutanoate CoA ligase (glycine + acetyl-CoA)", "ec": "2.3.1.29", "equation": "L-2-Amino-3-oxobutanoate + CoA <=> Glycine + Acetyl-CoA", "substrates": [ { "metabolite": "amino_oxobutanoate" }, { "metabolite": "coa" } ], "products": [ { "metabolite": "glycine" }, { "metabolite": "accoa" } ], "catalysts": [ { "enzyme": "gcat", "role": "catalyst" } ], "reversibility": "reversible", "pathwayStep": 9, "compartment": "mitochondrion", "xrefs": { "kegg": "R00371" }, "provenance": { "confidence": "low", "sources": [ { "db": "KEGG", "id": "R00371" }, { "db": "UniProt", "id": "O75600" } ], "notes": "Canonical threonine->glycine route via TDH then GCAT. In humans this is largely inactive because L-threonine 3-dehydrogenase (TDH) that would supply L-2-amino-3-oxobutanoate is a pseudogene; GCAT is expressed but its principal in vivo role (and net direction) is uncertain. Reaction retained for completeness with low confidence." } },
    { "id": "gsr10", "name": "Choline oxidation to betaine aldehyde", "ec": "1.1.99.1", "equation": "Choline + [acceptor] -> Betaine aldehyde + [reduced acceptor]", "substrates": [ { "metabolite": "choline" } ], "products": [ { "metabolite": "betaine_aldehyde" } ], "catalysts": [ { "enzyme": "chdh", "role": "catalyst" } ], "reversibility": "irreversible", "pathwayStep": 10, "compartment": "mitochondrion", "xrefs": { "kegg": "R01025" }, "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R01025" }, { "db": "UniProt", "id": "Q8NE62" } ], "notes": "FAD-dependent inner-mitochondrial-membrane flavoprotein; electrons pass to ubiquinone/ETF (electron acceptor omitted as it is a protein/quinone carrier, not a small-molecule couple)." } },
    { "id": "gsr11", "name": "Betaine aldehyde dehydrogenation to betaine", "ec": "1.2.1.8", "equation": "Betaine aldehyde + NAD+ + H2O -> Glycine betaine + NADH + 2 H+", "substrates": [ { "metabolite": "betaine_aldehyde" }, { "metabolite": "nad" }, { "metabolite": "h2o" } ], "products": [ { "metabolite": "betaine" }, { "metabolite": "nadh" }, { "metabolite": "hplus", "stoichiometry": 2 } ], "catalysts": [ { "enzyme": "aldh7a1", "role": "catalyst" } ], "cofactors": [ { "metabolite": "nad", "role": "electron acceptor" } ], "reversibility": "irreversible", "pathwayStep": 11, "compartment": "mitochondrion", "xrefs": { "kegg": "R02565" }, "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R02565" }, { "db": "UniProt", "id": "P49419" } ] } },
    { "id": "gsr12", "name": "Betaine-dependent remethylation of homocysteine", "ec": "2.1.1.5", "equation": "Glycine betaine + L-Homocysteine -> N,N-Dimethylglycine + L-Methionine", "substrates": [ { "metabolite": "betaine" }, { "metabolite": "homocysteine" } ], "products": [ { "metabolite": "dmglycine" }, { "metabolite": "methionine" } ], "catalysts": [ { "enzyme": "bhmt", "role": "catalyst" } ], "cofactors": [ { "metabolite": "betaine", "role": "methyl donor" } ], "reversibility": "direction-forward", "pathwayStep": 12, "compartment": "cytosol", "xrefs": { "kegg": "R02821" }, "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R02821" }, { "db": "UniProt", "id": "Q93088" } ], "notes": "Liver/kidney-restricted, folate-independent branch of the methionine cycle; links this module to methionine/SAM metabolism." } },
    { "id": "gsr13", "name": "Dimethylglycine oxidative demethylation", "ec": "1.5.8.4", "equation": "N,N-Dimethylglycine + Tetrahydrofolate -> Sarcosine + 5,10-Methylenetetrahydrofolate", "substrates": [ { "metabolite": "dmglycine" }, { "metabolite": "thf" } ], "products": [ { "metabolite": "sarcosine" }, { "metabolite": "mlthf" } ], "catalysts": [ { "enzyme": "dmgdh", "role": "catalyst" } ], "cofactors": [ { "metabolite": "thf", "role": "one-carbon acceptor" } ], "reversibility": "irreversible", "pathwayStep": 13, "compartment": "mitochondrion", "xrefs": { "kegg": "R01565" }, "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R01565" }, { "db": "UniProt", "id": "Q9UI17" } ], "notes": "FAD flavoprotein; the released one-carbon unit is captured by THF as 5,10-methylene-THF, and reducing equivalents pass to electron-transferring flavoprotein (ETF, a protein carrier, not shown)." } },
    { "id": "gsr14", "name": "Sarcosine oxidative demethylation to glycine", "ec": "1.5.8.3", "equation": "Sarcosine + Tetrahydrofolate -> Glycine + 5,10-Methylenetetrahydrofolate", "substrates": [ { "metabolite": "sarcosine" }, { "metabolite": "thf" } ], "products": [ { "metabolite": "glycine" }, { "metabolite": "mlthf" } ], "catalysts": [ { "enzyme": "sardh", "role": "catalyst" } ], "cofactors": [ { "metabolite": "thf", "role": "one-carbon acceptor" } ], "reversibility": "irreversible", "pathwayStep": 14, "compartment": "mitochondrion", "xrefs": { "kegg": "R00611" }, "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R00611" }, { "db": "UniProt", "id": "Q9UL12" } ], "notes": "FAD flavoprotein passing electrons to ETF (protein carrier, not shown); completes choline -> betaine -> glycine and donates a second one-carbon unit to the folate pool." } },
