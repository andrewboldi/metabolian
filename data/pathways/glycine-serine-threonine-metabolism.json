  "regulations": [
    { "id": "reg_ser_phgdh", "type": "feedback-inhibition", "regulator": { "kind": "metabolite", "id": "serine" }, "target": { "kind": "enzyme", "id": "phgdh" }, "effect": "negative", "mechanism": "L-Serine, the pathway end product, allosterically feeds back on PHGDH (ACT/regulatory domain). Feedback is strong in bacteria but comparatively weak/permissive in humans, which allows serine-synthesis flux to remain high in proliferating and PHGDH-amplified cells.", "provenance": { "confidence": "medium", "sources": [ { "db": "textbook", "id": "Lehninger 8e, Ch. 22" }, { "db": "PubMed", "id": "27641100" } ] } },
    { "id": "reg_atf4_phgdh", "type": "transcriptional-activation", "regulator": { "kind": "enzyme", "id": "atf4" }, "target": { "kind": "gene", "id": "phgdh_g" }, "effect": "positive", "mechanism": "ATF4 (integrated stress response, downstream of GCN2/mTORC1 and the NRF2 axis) transactivates PHGDH, driving serine-synthesis-pathway upregulation in stressed and cancer cells.", "provenance": { "confidence": "medium", "sources": [ { "db": "PubMed", "id": "26482881" } ] } },
    { "id": "reg_atf4_psat1", "type": "transcriptional-activation", "regulator": { "kind": "enzyme", "id": "atf4" }, "target": { "kind": "gene", "id": "psat1_g" }, "effect": "positive", "mechanism": "ATF4 transactivates PSAT1 as part of coordinated serine/glycine synthesis induction.", "provenance": { "confidence": "medium", "sources": [ { "db": "PubMed", "id": "26482881" } ] } },
    { "id": "reg_atf4_psph", "type": "transcriptional-activation", "regulator": { "kind": "enzyme", "id": "atf4" }, "target": { "kind": "gene", "id": "psph_g" }, "effect": "positive", "mechanism": "ATF4 transactivates PSPH, completing induction of the three serine-synthesis enzymes.", "provenance": { "confidence": "medium", "sources": [ { "db": "PubMed", "id": "26482881" } ] } },
    { "id": "reg_atf4_shmt2", "type": "transcriptional-activation", "regulator": { "kind": "enzyme", "id": "atf4" }, "target": { "kind": "gene", "id": "shmt2_g" }, "effect": "positive", "mechanism": "ATF4 induces the mitochondrial one-carbon enzyme SHMT2, coupling serine synthesis to mitochondrial one-carbon output (formate, NADPH, glycine).", "provenance": { "confidence": "medium", "sources": [ { "db": "PubMed", "id": "26482881" }, { "db": "PubMed", "id": "29073064" } ] } },
    { "id": "reg_5mthf_gnmt", "type": "allosteric-inhibition", "regulator": { "kind": "metabolite", "id": "mthf5" }, "target": { "kind": "enzyme", "id": "gnmt" }, "effect": "negative", "mechanism": "5-Methyltetrahydrofolate binds and inhibits glycine N-methyltransferase, coupling folate status to SAM-dependent methylation: when 5-methyl-THF (and thus methionine-cycle flux) is high, GNMT-mediated SAM disposal is restrained.", "provenance": { "confidence": "medium", "sources": [ { "db": "PubMed", "id": "22037183" } ] } }
