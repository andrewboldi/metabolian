    { "id": "gsr16", "name": "Glyoxylate transamination to glycine (peroxisomal)", "ec": "2.6.1.44", "equation": "L-Alanine + Glyoxylate <=> Pyruvate + Glycine", "substrates": [ { "metabolite": "alanine" }, { "metabolite": "glyoxylate" } ], "products": [ { "metabolite": "pyruvate" }, { "metabolite": "glycine" } ], "catalysts": [ { "enzyme": "agxt", "role": "catalyst" } ], "reversibility": "reversible", "pathwayStep": 16, "compartment": "peroxisome", "xrefs": { "kegg": "R00369" }, "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R00369" }, { "db": "UniProt", "id": "P21549" }, { "db": "PubMed", "id": "2363689" } ], "notes": "Physiologically detoxifies glyoxylate to glycine in peroxisomes; AGXT loss-of-function or peroxisome-to-mitochondrion mistargeting causes primary hyperoxaluria type 1." } },
    { "id": "gsr17", "name": "Serine racemization", "ec": "5.1.1.18", "equation": "L-Serine <=> D-Serine", "substrates": [ { "metabolite": "serine" } ], "products": [ { "metabolite": "dserine" } ], "catalysts": [ { "enzyme": "srr", "role": "catalyst" } ], "reversibility": "reversible", "pathwayStep": 17, "compartment": "cytosol", "xrefs": { "kegg": "R00589" }, "provenance": { "confidence": "high", "sources": [ { "db": "KEGG", "id": "R00589" }, { "db": "UniProt", "id": "Q9GZT4" }, { "db": "PubMed", "id": "10557334" } ], "notes": "PLP-dependent; D-serine is the principal co-agonist at the NMDA-receptor glycine site in brain." } }
