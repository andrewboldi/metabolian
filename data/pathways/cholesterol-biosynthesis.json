    { "id": "chol13", "name": "Lanosterol synthase (oxidosqualene cyclization)", "ec": "5.4.99.7", "equation": "(S)-2,3-Epoxysqualene -> Lanosterol", "substrates": [{ "metabolite": "epoxysqualene" }], "products": [{ "metabolite": "lanosterol" }], "catalysts": [{ "enzyme": "lss", "role": "catalyst" }], "reversibility": "irreversible", "pathwayStep": 13, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R03199" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R03199" }], "notes": "Cascade polycyclization forms the fused four-ring steroid nucleus; lanosterol is the first sterol." } },
