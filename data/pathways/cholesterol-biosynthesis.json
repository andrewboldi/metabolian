    { "id": "chol17", "name": "Sterol-4alpha-carboxylate 3-dehydrogenase (decarboxylation)", "ec": "1.1.1.170", "equation": "4alpha-Methylzymosterol-4-carboxylate + NAD+ -> 3-Keto-4-methylzymosterol + CO2 + NADH", "substrates": [{ "metabolite": "methylzymosterol_carboxylate" }, { "metabolite": "nad" }], "products": [{ "metabolite": "keto_methylzymosterol" }, { "metabolite": "co2" }, { "metabolite": "nadh" }], "catalysts": [{ "enzyme": "nsdhl", "role": "catalyst" }], "cofactors": [{ "metabolite": "nad", "role": "electron acceptor" }], "reversibility": "irreversible", "pathwayStep": 17, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R07494" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R07494" }], "notes": "Oxidative decarboxylation with concomitant 3-hydroxyl oxidation. Cofactor shown as NAD+ per UniProt Q15738; KEGG R07494 annotates the NADP+ form." } },
    { "id": "chol18", "name": "3-keto-steroid reductase (C3 keto reduction)", "ec": "1.1.1.270", "equation": "3-Keto-4-methylzymosterol + NADPH + H+ -> 4alpha-Methylzymosterol + NADP+", "substrates": [{ "metabolite": "keto_methylzymosterol" }, { "metabolite": "nadph" }, { "metabolite": "hplus" }], "products": [{ "metabolite": "methylzymosterol" }, { "metabolite": "nadp" }], "catalysts": [{ "enzyme": "hsd17b7", "role": "catalyst" }], "cofactors": [{ "metabolite": "nadph", "role": "reductant" }], "reversibility": "irreversible", "pathwayStep": 18, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R07495" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R07495" }] } },
    { "id": "chol19", "name": "Methylsterol monooxygenase (second C4 demethylation: methyl to carboxyl)", "ec": "1.14.18.9", "equation": "4alpha-Methylzymosterol + 3 O2 + 3 NADH (via cytochrome b5) + 2 H+ -> 4alpha-Carboxy-5alpha-cholesta-8,24-dien-3beta-ol + 3 NAD+ + 4 H2O", "substrates": [{ "metabolite": "methylzymosterol" }, { "metabolite": "o2", "stoichiometry": 3 }, { "metabolite": "nadh", "stoichiometry": 3 }, { "metabolite": "hplus", "stoichiometry": 2 }], "products": [{ "metabolite": "carboxy_cholestadienol" }, { "metabolite": "nad", "stoichiometry": 3 }, { "metabolite": "h2o", "stoichiometry": 4 }], "catalysts": [{ "enzyme": "msmo1", "role": "catalyst" }], "cofactors": [{ "metabolite": "o2", "role": "oxygen donor" }, { "metabolite": "nadh", "role": "electron donor via cytochrome b5" }], "reversibility": "irreversible", "pathwayStep": 19, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R12403" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R12403" }], "notes": "Removes the second 4alpha-methyl. Reductant stoichiometry simplified from the cytochrome-b5 form in KEGG R12403." } },
    { "id": "chol20", "name": "Sterol-4alpha-carboxylate 3-dehydrogenase (second decarboxylation)", "ec": "1.1.1.170", "equation": "4alpha-Carboxy-5alpha-cholesta-8,24-dien-3beta-ol + NAD+ -> Zymosterone + CO2 + NADH", "substrates": [{ "metabolite": "carboxy_cholestadienol" }, { "metabolite": "nad" }], "products": [{ "metabolite": "zymosterone" }, { "metabolite": "co2" }, { "metabolite": "nadh" }], "catalysts": [{ "enzyme": "nsdhl", "role": "catalyst" }], "cofactors": [{ "metabolite": "nad", "role": "electron acceptor" }], "reversibility": "irreversible", "pathwayStep": 20, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R12404" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R12404" }] } },
    { "id": "chol21", "name": "3-keto-steroid reductase (C3 keto reduction to zymosterol)", "ec": "1.1.1.270", "equation": "Zymosterone + NADPH + H+ -> Zymosterol + NADP+", "substrates": [{ "metabolite": "zymosterone" }, { "metabolite": "nadph" }, { "metabolite": "hplus" }], "products": [{ "metabolite": "zymosterol" }, { "metabolite": "nadp" }], "catalysts": [{ "enzyme": "hsd17b7", "role": "catalyst" }], "cofactors": [{ "metabolite": "nadph", "role": "reductant" }], "reversibility": "irreversible", "pathwayStep": 21, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R12405" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R12405" }] } },
    { "id": "chol22", "name": "24-dehydrocholesterol reductase (Delta-24 reduction; Kandutsch–Russell branch)", "ec": "1.3.1.72", "equation": "Zymosterol + NADPH + H+ -> 5alpha-Cholest-8-en-3beta-ol (zymostenol) + NADP+", "substrates": [{ "metabolite": "zymosterol" }, { "metabolite": "nadph" }, { "metabolite": "hplus" }], "products": [{ "metabolite": "zymostenol" }, { "metabolite": "nadp" }], "catalysts": [{ "enzyme": "dhcr24", "role": "catalyst" }], "cofactors": [{ "metabolite": "nadph", "role": "reductant" }], "reversibility": "irreversible", "pathwayStep": 22, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R07498" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R07498" }], "notes": "In the Kandutsch–Russell route DHCR24 reduces the side-chain Δ24 bond here; in the Bloch route the same enzyme instead acts last, on desmosterol (reaction chol26)." } },
    { "id": "chol23", "name": "3-beta-hydroxysteroid-Delta(8),Delta(7)-isomerase", "ec": "5.3.3.5", "equation": "5alpha-Cholest-8-en-3beta-ol -> Lathosterol (5alpha-cholest-7-en-3beta-ol)", "substrates": [{ "metabolite": "zymostenol" }], "products": [{ "metabolite": "lathosterol" }], "catalysts": [{ "enzyme": "ebp", "role": "catalyst" }], "reversibility": "reversible", "pathwayStep": 23, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R03353" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R03353" }], "notes": "Shifts the ring double bond from Δ8 to Δ7. EBP is the target of CDPX2 (Conradi–Hünermann–Happle) mutations." } },
    { "id": "chol24", "name": "Lathosterol 5-desaturase (sterol C5-desaturation)", "ec": "1.14.19.20", "equation": "Lathosterol + O2 + NADH (via cytochrome b5) + H+ -> 7-Dehydrocholesterol + 2 H2O + NAD+", "substrates": [{ "metabolite": "lathosterol" }, { "metabolite": "o2" }, { "metabolite": "nadh" }, { "metabolite": "hplus" }], "products": [{ "metabolite": "dehydrocholesterol_7" }, { "metabolite": "h2o", "stoichiometry": 2 }, { "metabolite": "nad" }], "catalysts": [{ "enzyme": "sc5d", "role": "catalyst" }], "cofactors": [{ "metabolite": "o2", "role": "oxygen/electron acceptor" }, { "metabolite": "nadh", "role": "electron donor via cytochrome b5" }], "reversibility": "irreversible", "pathwayStep": 24, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R07215" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R07215" }], "notes": "Introduces the Δ5 double bond; electrons supplied by cytochrome b5. Deficiency causes lathosterolosis." } },
    { "id": "chol25", "name": "7-dehydrocholesterol reductase (final step)", "ec": "1.3.1.21", "equation": "7-Dehydrocholesterol + NADPH + H+ -> Cholesterol + NADP+", "substrates": [{ "metabolite": "dehydrocholesterol_7" }, { "metabolite": "nadph" }, { "metabolite": "hplus" }], "products": [{ "metabolite": "cholesterol" }, { "metabolite": "nadp" }], "catalysts": [{ "enzyme": "dhcr7", "role": "catalyst" }], "cofactors": [{ "metabolite": "nadph", "role": "reductant" }], "reversibility": "irreversible", "pathwayStep": 25, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R01456" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R01456" }], "notes": "Terminal reduction of the Δ7 bond (Kandutsch–Russell route). DHCR7 loss-of-function causes Smith–Lemli–Opitz syndrome, with 7-dehydrocholesterol accumulation." } },
    { "id": "chol26", "name": "24-dehydrocholesterol reductase (Bloch-branch terminal step)", "ec": "1.3.1.72", "equation": "Desmosterol + NADPH + H+ -> Cholesterol + NADP+", "substrates": [{ "metabolite": "desmosterol" }, { "metabolite": "nadph" }, { "metabolite": "hplus" }], "products": [{ "metabolite": "cholesterol" }, { "metabolite": "nadp" }], "catalysts": [{ "enzyme": "dhcr24", "role": "catalyst" }], "cofactors": [{ "metabolite": "nadph", "role": "reductant" }], "reversibility": "irreversible", "pathwayStep": 26, "compartment": "endoplasmic-reticulum", "xrefs": { "kegg": "R01457" }, "provenance": { "confidence": "high", "sources": [{ "db": "KEGG", "id": "R01457" }], "notes": "Terminal step of the parallel Bloch route: desmosterol (generated when the Δ24 bond is retained through the C4/C14 demethylations and Δ5-desaturation) is reduced to cholesterol. DHCR24 loss causes desmosterolosis." } }
