  "regulations": [
    { "id": "reg_accoa_pc", "type": "allosteric-activation", "regulator": { "kind": "metabolite", "id": "accoa" }, "target": { "kind": "enzyme", "id": "pc" }, "effect": "positive", "mechanism": "Acetyl-CoA is an obligatory allosteric activator of pyruvate carboxylase; the enzyme is essentially inactive without it, coupling high fatty-acid oxidation (abundant acetyl-CoA) to gluconeogenic flux.", "provenance": { "confidence": "high", "sources": [{ "db": "textbook", "id": "Lehninger 8e, Ch. 14" }] } },
    { "id": "reg_f26bp_fbp1", "type": "allosteric-inhibition", "regulator": { "kind": "metabolite", "id": "f26bp" }, "target": { "kind": "enzyme", "id": "fbp1" }, "effect": "negative", "mechanism": "Fructose-2,6-bisphosphate allosterically inhibits FBPase-1 (while activating PFK-1). It is the master signal for reciprocal control of gluconeogenesis and glycolysis; its level is hormonally set by the bifunctional PFK-2/FBPase-2 enzyme.", "provenance": { "confidence": "high", "sources": [{ "db": "textbook", "id": "Lehninger 8e, Ch. 15" }, { "db": "PubMed", "id": "28731034" }] } },
    { "id": "reg_amp_fbp1", "type": "allosteric-inhibition", "regulator": { "kind": "metabolite", "id": "amp" }, "target": { "kind": "enzyme", "id": "fbp1" }, "effect": "negative", "mechanism": "AMP (low energy charge) allosterically inhibits FBPase-1 synergistically with fructose-2,6-bisphosphate; the same AMP activates PFK-1, ensuring glycolysis and gluconeogenesis are not both fully active.", "provenance": { "confidence": "high", "sources": [{ "db": "textbook", "id": "Lehninger 8e, Ch. 15" }] } },
    { "id": "reg_citrate_fbp1", "type": "allosteric-activation", "regulator": { "kind": "metabolite", "id": "citrate" }, "target": { "kind": "enzyme", "id": "fbp1" }, "effect": "positive", "mechanism": "Citrate (signalling abundant biosynthetic precursors) allosterically activates FBPase-1 while inhibiting PFK-1, reinforcing the switch toward glucose synthesis.", "provenance": { "confidence": "medium", "sources": [{ "db": "textbook", "id": "Stryer Biochemistry, 9e" }] } },
    { "id": "reg_glucagon_fbp1", "type": "hormonal-signal", "regulator": { "kind": "metabolite", "id": "glucagon" }, "target": { "kind": "enzyme", "id": "fbp1" }, "effect": "signal", "mechanism": "Fasting glucagon raises cAMP, activating PKA, which phosphorylates the liver bifunctional PFK-2/FBPase-2 enzyme; the FBPase-2 domain is switched on and fructose-2,6-bisphosphate falls, relieving FBPase-1 inhibition and stimulating gluconeogenesis.", "provenance": { "confidence": "high", "sources": [{ "db": "textbook", "id": "Lehninger 8e, Ch. 15" }, { "db": "PubMed", "id": "28731034" }] } },
    { "id": "reg_camp_pck1", "type": "transcriptional-activation", "regulator": { "kind": "metabolite", "id": "camp" }, "target": { "kind": "gene", "id": "gene_pck1" }, "effect": "positive", "mechanism": "Glucagon-driven cAMP/PKA activates CREB (with coactivators CRTC2 and PGC-1alpha) to induce transcription of cytosolic PEPCK (PCK1), raising gluconeogenic capacity during fasting.", "provenance": { "confidence": "high", "sources": [{ "db": "textbook", "id": "Lehninger 8e, Ch. 23" }, { "db": "PubMed", "id": "28731034" }] } },
    { "id": "reg_camp_g6pc", "type": "transcriptional-activation", "regulator": { "kind": "metabolite", "id": "camp" }, "target": { "kind": "gene", "id": "gene_g6pc" }, "effect": "positive", "mechanism": "The cAMP/CREB/PGC-1alpha and glucocorticoid/FOXO1 axes induce glucose-6-phosphatase (G6PC1) transcription in fasting liver, increasing hepatic glucose output.", "provenance": { "confidence": "high", "sources": [{ "db": "PubMed", "id": "28731034" }] } },
    { "id": "reg_insulin_pck1", "type": "transcriptional-repression", "regulator": { "kind": "metabolite", "id": "insulin" }, "target": { "kind": "gene", "id": "gene_pck1" }, "effect": "negative", "mechanism": "In the fed state, insulin activates PI3K/AKT, which phosphorylates FOXO1 and excludes it from the nucleus, repressing PEPCK (PCK1) transcription and suppressing gluconeogenesis.", "provenance": { "confidence": "high", "sources": [{ "db": "PubMed", "id": "28868790" }] } },
    { "id": "reg_insulin_g6pc", "type": "transcriptional-repression", "regulator": { "kind": "metabolite", "id": "insulin" }, "target": { "kind": "gene", "id": "gene_g6pc" }, "effect": "negative", "mechanism": "Insulin/AKT/FOXO1 signalling likewise represses glucose-6-phosphatase (G6PC1) transcription, lowering hepatic glucose output.", "provenance": { "confidence": "high", "sources": [{ "db": "PubMed", "id": "28868790" }] } }
