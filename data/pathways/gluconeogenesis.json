  "relations": [
    { "id": "rel_gng_glycolysis", "type": "crosstalk", "source": { "kind": "metabolite", "id": "pyruvate" }, "target": { "kind": "pathway", "id": "glycolysis" }, "note": "Gluconeogenesis is the biosynthetic opposite of glycolysis: they share seven near-equilibrium enzymes (steps 6-13 here) but gluconeogenesis bypasses the three irreversible glycolytic steps with four enzymes (pyruvate carboxylase + PEPCK, FBPase-1, glucose-6-phosphatase). The two are reciprocally regulated to avoid a futile ATP-wasting cycle." },
    { "id": "rel_gng_tca", "type": "crosstalk", "source": { "kind": "metabolite", "id": "oaa" }, "target": { "kind": "pathway", "id": "citric-acid-cycle" }, "note": "Oxaloacetate is shared with the TCA cycle: anaplerotic OAA (from pyruvate carboxylase) and glucogenic amino acids entering the cycle are withdrawn (cataplerosis) toward glucose, and mitochondrial GTP for PEPCK is supplied by the succinyl-CoA synthetase step." },
    { "id": "rel_gng_ppp", "type": "crosstalk", "source": { "kind": "metabolite", "id": "g6p" }, "target": { "kind": "pathway", "id": "pentose-phosphate-pathway" }, "note": "Glucose 6-phosphate made by gluconeogenesis can be routed into the pentose phosphate pathway for NADPH and ribose 5-phosphate instead of being dephosphorylated to free glucose." },
    { "id": "rel_gng_glycogen", "type": "crosstalk", "source": { "kind": "metabolite", "id": "g6p" }, "target": { "kind": "pathway", "id": "glycogenesis" }, "note": "Gluconeogenic glucose 6-phosphate is a precursor for hepatic glycogen synthesis (the 'indirect pathway' of glycogen repletion after a fast)." },
    { "id": "rel_gng_aa", "type": "crosstalk", "source": { "kind": "metabolite", "id": "pyruvate" }, "target": { "kind": "pathway", "id": "amino-acid-metabolism" }, "note": "Glucogenic amino acids feed gluconeogenesis: alanine (glucose-alanine cycle) and serine/glycine/cysteine converge on pyruvate, while others enter as oxaloacetate or TCA intermediates. Lactate from anaerobic tissues (Cori cycle) enters as pyruvate, and glycerol from lipolysis enters at DHAP." },
    { "id": "rel_isozyme_pck", "type": "isozyme", "source": { "kind": "enzyme", "id": "pck1" }, "target": { "kind": "enzyme", "id": "pck2" }, "note": "Cytosolic (PCK1) and mitochondrial (PCK2) PEPCK isozymes catalyze the same oxaloacetate -> PEP reaction in different compartments; their relative contribution is tissue- and species-dependent." },
    { "id": "rel_isozyme_mdh", "type": "isozyme", "source": { "kind": "enzyme", "id": "mdh1" }, "target": { "kind": "enzyme", "id": "mdh2" }, "note": "Cytosolic (MDH1) and mitochondrial (MDH2) malate dehydrogenases catalyze the same reaction and together run the malate shuttle that exports reducing equivalents for gluconeogenesis." },
    { "id": "rel_gene_pck1", "type": "gene-encodes", "source": { "kind": "gene", "id": "gene_pck1" }, "target": { "kind": "enzyme", "id": "pck1" }, "note": "The PCK1 gene encodes cytosolic PEPCK, a primary transcriptional control node for gluconeogenesis." },
    { "id": "rel_gene_g6pc", "type": "gene-encodes", "source": { "kind": "gene", "id": "gene_g6pc" }, "target": { "kind": "enzyme", "id": "g6pc" }, "note": "The G6PC1 gene encodes the glucose-6-phosphatase catalytic subunit, the terminal and hormonally regulated step of hepatic/renal glucose output." }
  ]
