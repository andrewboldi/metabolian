{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://andrewboldi.github.io/metabolian/schema/pathway.schema.json",
  "title": "Metabolian Pathway Module",
  "description": "One self-contained metabolic pathway module. Every research agent authors one of these as data/pathways/<id>.json. Files are conflict-free (one pathway per file) and merged into the master graph by tools/build-graph. Every reaction and regulatory edge MUST carry provenance so the atlas is auditable, never fabricated.",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "provenance",
    "metabolites",
    "enzymes",
    "reactions"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Stable kebab-case module id, e.g. 'glycolysis'."
    },
    "name": {
      "type": "string",
      "minLength": 2
    },
    "category": {
      "type": "string",
      "enum": [
        "carbohydrate-metabolism",
        "lipid-metabolism",
        "amino-acid-metabolism",
        "nucleotide-metabolism",
        "energy-metabolism",
        "cofactor-vitamin-metabolism",
        "signaling",
        "redox-detox",
        "one-carbon-metabolism",
        "microbiome-host",
        "cancer-rewiring",
        "hormone-endocrine",
        "neurotransmitter-metabolism",
        "specialized-tissue",
        "transport",
        "other"
      ]
    },
    "summary": {
      "type": "string",
      "description": "One-sentence plain-language summary."
    },
    "description": {
      "type": "string",
      "description": "Longer markdown description."
    },
    "organisms": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "human"
      ]
    },
    "tissues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "compartments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/compartment"
      }
    },
    "metabolites": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metabolite"
      }
    },
    "enzymes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/enzyme"
      }
    },
    "genes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gene"
      }
    },
    "complexes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/complex"
      }
    },
    "reactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reaction"
      }
    },
    "regulations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/regulation"
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      }
    }
  },
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "hypothesis"
      ],
      "description": "high = textbook/curated DB consensus; medium = well-supported primary literature; low = single source / preliminary; hypothesis = model-suggested, unverified."
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pmid": {
          "type": "string"
        },
        "doi": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "year": {
          "type": "integer"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "xref": {
      "type": "object",
      "description": "Cross-references to authoritative databases. Prefer stable IDs; the merge step dedupes entities across modules by these.",
      "additionalProperties": true,
      "properties": {
        "chebi": {
          "type": "string"
        },
        "kegg": {
          "type": "string"
        },
        "pubchem": {
          "type": "string"
        },
        "hmdb": {
          "type": "string"
        },
        "metacyc": {
          "type": "string"
        },
        "inchikey": {
          "type": "string"
        },
        "uniprot": {
          "type": "string"
        },
        "pdb": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "alphafold": {
          "type": "string"
        },
        "rhea": {
          "type": "string"
        },
        "reactome": {
          "type": "string"
        },
        "brenda": {
          "type": "string"
        },
        "ensembl": {
          "type": "string"
        },
        "entrez": {
          "type": "string"
        },
        "go": {
          "type": "string"
        },
        "ec": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metanetx": {
          "type": "string",
          "description": "MetaNetX (MNXref) identifier, e.g. MNXM729302 or MNXR100024. Used for compounds and reactions reconciled from KEGG/MetaCyc/SEED/BiGG that have no ChEBI or Rhea equivalent."
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "confidence",
        "sources"
      ],
      "additionalProperties": false,
      "properties": {
        "curator": {
          "type": "string",
          "description": "Agent or human that authored/reviewed this."
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "db"
            ],
            "additionalProperties": false,
            "properties": {
              "db": {
                "type": "string",
                "enum": [
                  "KEGG",
                  "Reactome",
                  "MetaCyc",
                  "MetaNetX",
                  "Rhea",
                  "BRENDA",
                  "UniProt",
                  "ChEBI",
                  "HMDB",
                  "PDB",
                  "AlphaFold",
                  "PubMed",
                  "textbook",
                  "review",
                  "other"
                ]
              },
              "id": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            }
          }
        },
        "lastReviewed": {
          "type": "string",
          "description": "ISO date."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "compartment": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "go": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "metabolite": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "name": {
          "type": "string"
        },
        "synonyms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "short": {
          "type": "string",
          "maxLength": 20,
          "description": "Chart caption form, when the curated name is too long to print on a side arc (e.g. \"5-CH3-THF\" for 5-methyltetrahydrofolate). The renderer already prefers this over the full name; without it in the schema, ingested modules could not supply one. Never a new name — an abbreviation of the curated one. Max 20 chars, matching the chart's caption gate."
        },
        "formula": {
          "type": "string"
        },
        "charge": {
          "type": "integer"
        },
        "monoisotopicMass": {
          "type": "number"
        },
        "smiles": {
          "type": "string"
        },
        "inchikey": {
          "type": "string"
        },
        "class": {
          "type": "string"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "fuel",
              "cofactor",
              "coenzyme",
              "second-messenger",
              "signaling",
              "vitamin",
              "hormone",
              "neurotransmitter",
              "electron-carrier",
              "building-block",
              "waste",
              "toxin",
              "other"
            ]
          }
        },
        "xrefs": {
          "$ref": "#/$defs/xref"
        },
        "description": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    },
    "enzyme": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "name": {
          "type": "string"
        },
        "gene": {
          "type": "string"
        },
        "ec": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "organism": {
          "type": "string"
        },
        "cofactors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "family": {
          "type": "string"
        },
        "compartment": {
          "type": "string"
        },
        "molecularWeightKda": {
          "type": "number"
        },
        "oligomerization": {
          "type": "string"
        },
        "tissues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "xrefs": {
          "$ref": "#/$defs/xref"
        },
        "description": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    },
    "gene": {
      "type": "object",
      "required": [
        "id",
        "symbol"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "xrefs": {
          "$ref": "#/$defs/xref"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "complex": {
      "type": "object",
      "required": [
        "id",
        "name",
        "subunits"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "subunits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "enzyme"
            ],
            "additionalProperties": false,
            "properties": {
              "enzyme": {
                "type": "string"
              },
              "stoichiometry": {
                "type": "number"
              }
            }
          }
        },
        "xrefs": {
          "$ref": "#/$defs/xref"
        },
        "description": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    },
    "participant": {
      "type": "object",
      "required": [
        "metabolite"
      ],
      "additionalProperties": false,
      "properties": {
        "metabolite": {
          "type": "string"
        },
        "stoichiometry": {
          "type": "number",
          "default": 1
        },
        "compartment": {
          "type": "string"
        }
      }
    },
    "reaction": {
      "type": "object",
      "required": [
        "id",
        "substrates",
        "products",
        "provenance"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "name": {
          "type": "string"
        },
        "ec": {
          "type": "string"
        },
        "equation": {
          "type": "string"
        },
        "substrates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/participant"
          }
        },
        "products": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/participant"
          }
        },
        "catalysts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "enzyme"
            ],
            "additionalProperties": false,
            "properties": {
              "enzyme": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "catalyst",
                  "transporter",
                  "rate-limiting",
                  "committed-step"
                ]
              }
            }
          }
        },
        "cofactors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "metabolite"
            ],
            "additionalProperties": false,
            "properties": {
              "metabolite": {
                "type": "string"
              },
              "role": {
                "type": "string"
              }
            }
          }
        },
        "reversibility": {
          "type": "string",
          "enum": [
            "reversible",
            "irreversible",
            "direction-forward",
            "direction-reverse",
            "unknown"
          ],
          "default": "unknown"
        },
        "deltaGPrimeKjPerMol": {
          "type": "number"
        },
        "kinetics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/kinetics"
          }
        },
        "spontaneous": {
          "type": "boolean",
          "default": false
        },
        "transport": {
          "type": "boolean",
          "default": false
        },
        "compartment": {
          "type": "string"
        },
        "rateLimiting": {
          "type": "boolean",
          "default": false
        },
        "pathwayStep": {
          "type": "number"
        },
        "xrefs": {
          "$ref": "#/$defs/xref"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    },
    "kinetics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enzyme": {
          "type": "string"
        },
        "substrate": {
          "type": "string"
        },
        "kmMilliMolar": {
          "type": "number"
        },
        "kcatPerSec": {
          "type": "number"
        },
        "vmax": {
          "type": "string"
        },
        "organism": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "endpoint": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "metabolite",
            "enzyme",
            "complex",
            "gene",
            "reaction",
            "pathway",
            "compartment"
          ]
        },
        "id": {
          "type": "string"
        }
      }
    },
    "regulation": {
      "type": "object",
      "required": [
        "id",
        "type",
        "regulator",
        "target",
        "provenance"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "activation",
            "inhibition",
            "allosteric-activation",
            "allosteric-inhibition",
            "competitive-inhibition",
            "noncompetitive-inhibition",
            "feedback-inhibition",
            "feedforward-activation",
            "phosphorylation",
            "dephosphorylation",
            "covalent-modification",
            "hormonal-signal",
            "transcriptional-activation",
            "transcriptional-repression"
          ]
        },
        "regulator": {
          "$ref": "#/$defs/endpoint"
        },
        "target": {
          "$ref": "#/$defs/endpoint"
        },
        "effect": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "neutral",
            "signal"
          ]
        },
        "mechanism": {
          "type": "string"
        },
        "conditions": {
          "type": "object",
          "additionalProperties": true
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    },
    "relation": {
      "type": "object",
      "required": [
        "id",
        "type",
        "source",
        "target"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "gene-encodes",
            "complex-formation",
            "isozyme",
            "pathway-membership",
            "crosstalk",
            "microbiome-host",
            "transport",
            "electron-transfer",
            "spontaneous"
          ]
        },
        "source": {
          "$ref": "#/$defs/endpoint"
        },
        "target": {
          "$ref": "#/$defs/endpoint"
        },
        "note": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    }
  }
}
